        },
        "method": "POST",
        "url": {
          "raw": "{{BASE_URL}}/carts/clean",
          "host": ["{{BASE_URL}}"],
          "path": ["carts", "clean"]
        }
      }
    },
    {
      "name": "✅ 7. CREATE ORDER - Minimal Payload",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  var jsonData = pm.response.json();",
              "  pm.environment.set('ORDER_ID', jsonData.data.id);",
              "  console.log('✅ Order created: ' + jsonData.data.id);",
              "} else {",
              "  console.log('❌ Failed: ' + pm.response.code);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{TOKEN}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"receiver_name\": \"Nguyễn Văn A\",\n  \"phone\": \"0901234567\",\n  \"shipping_address\": \"123 Đường ABC, Quận 1, TP.HCM\",\n  \"payment_method\": \"COD\",\n  \"items\": [\n    {\n      \"product_variant_id\": 5,\n      \"quantity\": 1\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/orders",
          "host": ["{{BASE_URL}}"],
          "path": ["orders"]
        }
      }
    },
