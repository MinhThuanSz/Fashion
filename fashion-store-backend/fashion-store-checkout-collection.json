          ]
        },
        "method": "DELETE",
        "url": {
          "raw": "{{BASE_URL}}/carts/items/1",
          "host": ["{{BASE_URL}}"],
          "path": ["carts", "items", "1"]
        }
      }
    },
    {
      "name": "🧹 6. CLEAN CART - Xóa items lỗi",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{TOKEN}}",
              "type": "string"
