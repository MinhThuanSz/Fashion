          ]
        },
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"quantity\": 3\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/carts/items/1",
          "host": ["{{BASE_URL}}"],
          "path": ["carts", "items", "1"]
        }
      }
    },
    {
      "name": "🗑️ 5. REMOVE FROM CART - Xóa sản phẩm",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{TOKEN}}",
              "type": "string"
